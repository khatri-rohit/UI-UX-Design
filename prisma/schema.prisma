generator client {
    provider = "prisma-client"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id               String           @id @default(uuid())
    clerkUserId      String?          @unique
    email            String           @unique
    name             String
    provider         Provider         @default(EMAIL)
    role             Role             @default(USER)
    organizationId   String?
    organizationSlug String?
    isActive         Boolean          @default(true)
    sessions         AppSession[]
    auditEvents      AuthAuditEvent[]
    createdAt        DateTime         @default(now())
    updatedAt        DateTime         @updatedAt
    projects         Projects[]
}

model AppSession {
    id             String        @id @default(cuid())
    userId         String
    clerkSessionId String        @unique
    status         SessionStatus @default(ACTIVE)
    issuedAt       DateTime
    expiresAt      DateTime?
    lastActiveAt   DateTime?
    ipAddress      String?
    userAgent      String?
    createdAt      DateTime      @default(now())
    updatedAt      DateTime      @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, createdAt])
    @@index([status])
}

model AuthAuditEvent {
    id             String           @id @default(cuid())
    userId         String?
    clerkUserId    String?
    clerkSessionId String?
    eventType      String
    eventSource    AuditEventSource @default(REQUEST)
    metadata       Json?
    createdAt      DateTime         @default(now())

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([userId, createdAt])
    @@index([clerkUserId, createdAt])
    @@index([clerkSessionId, createdAt])
}

model ClerkWebhookEvent {
    id         String   @id
    eventType  String
    receivedAt DateTime @default(now())
}

model Projects {
    id            String   @id @default(cuid())
    userId        String
    title         String
    description   String?
    initialPrompt String?
    canvasState   Json?
    thumbnailUrl  String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    generations Generation[]

    @@index([userId, createdAt])
    @@map("Projects")
}

model Generation {
    id        String   @id @default(cuid())
    projectId String
    model     String
    spec      Json
    prompt    String
    screens   Json?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    project Projects @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId, createdAt])
    @@map("generations")
}

enum Role {
    USER
    DEVELOPER
    ADMIN
}

enum Provider {
    GOOGLE
    GITHUB
    EMAIL
}

enum SessionStatus {
    ACTIVE
    ENDED
    REVOKED
}

enum AuditEventSource {
    REQUEST
    WEBHOOK
    SYSTEM
}
